page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, sans-serif;
  color: #1A202C;
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: 0 32rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.btn-primary {
  background: #FF6B6B;
  color: #FFFFFF;
  border-radius: 48rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #F8FAFC;
  color: #2C3E50;
  border-radius: 48rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: 1rpx solid #E2E8F0;
}

.btn-secondary::after {
  border: none;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #718096;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8FAFC;
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  border: 1rpx solid #E2E8F0;
}

.form-input:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 128rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #718096;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #A0AEC0;
}