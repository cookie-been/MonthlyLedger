.detail-page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 160rpx;
}

.detail-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 120rpx 48rpx 80rpx;
  color: #FFFFFF;
}

.detail-back {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  margin-bottom: 32rpx;
}

.detail-title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.detail-amount {
  font-size: 84rpx;
  font-weight: 800;
  margin-bottom: 32rpx;
}

.detail-progress {
  height: 16rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 8rpx;
  overflow: hidden;
}

.detail-progress-fill {
  height: 100%;
  background: #FFFFFF;
  border-radius: 8rpx;
}

.detail-info {
  background: #FFFFFF;
  margin: -40rpx 40rpx 40rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  color: #718096;
}

.detail-value {
  font-weight: 600;
}

.suggestion-section {
  background: #FFFFFF;
  margin: 0 40rpx 40rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.suggestion-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.suggestion-card {
  padding: 32rpx;
  background: #F8FAFC;
  border-radius: 24rpx;
}

.suggestion-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.suggestion-card-name {
  font-size: 30rpx;
  font-weight: 600;
}

.suggestion-card-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
}

.suggestion-card-tag.snowball {
  background: #FFF0F0;
  color: #FF6B6B;
}

.suggestion-card-desc {
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 16rpx;
}

.suggestion-card-reason {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.timeline-section {
  background: #FFFFFF;
  margin: 0 40rpx 40rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.timeline-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.timeline-item {
  position: relative;
  padding-left: 80rpx;
  padding-bottom: 48rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E2E8F0;
  border: 4rpx solid #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
}

.timeline-item.completed .timeline-dot {
  background: #4ECDC4;
  border-color: #4ECDC4;
}

.timeline-item.current .timeline-dot {
  background: #3498DB;
  border-color: #3498DB;
}

.timeline-line {
  position: absolute;
  left: 22rpx;
  top: 48rpx;
  width: 4rpx;
  height: calc(100% - 48rpx);
  background: #E2E8F0;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-content {
  padding-left: 16rpx;
}

.timeline-period {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.timeline-amount {
  font-size: 26rpx;
  color: #718096;
}

.detail-actions {
  display: flex;
  gap: 24rpx;
  margin: 0 40rpx 40rpx;
}

.detail-actions .btn-secondary,
.detail-actions .btn-primary {
  flex: 1;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
}

.modal.active {
  display: flex;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 56rpx;
  width: 85%;
  max-width: 720rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40rpx;
}

.btn-primary, .btn-secondary {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after, .btn-secondary::after {
  border: none;
}