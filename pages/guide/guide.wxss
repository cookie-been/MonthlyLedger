.guide-page {
  min-height: 100vh;
  background: #F5F7FA;
}

.guide-content {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.guide-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.guide-section.highlight {
  background: linear-gradient(135deg, #FFF5F5 0%, #FFFAF0 100%);
  border-left: 8rpx solid #FF6B6B;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 24rpx;
}

.section-content {
  padding-left: 16rpx;
}

.item {
  font-size: 28rpx;
  color: #4A5568;
  line-height: 1.8;
  padding: 8rpx 0;
}