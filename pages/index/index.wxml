<view class="index-page">
  <view class="home-header">
    <view class="header-top">
      <view class="header-title">月月账单</view>
      <view class="header-actions">
        <view class="header-btn" bindtap="showNotifications">🔔</view>
        <view class="header-btn" bindtap="goSettings">⚙️</view>
      </view>
    </view>
  </view>

  <view class="main-card">
    <view class="main-card-header">
      <view class="main-card-label">总负债</view>
      <view class="hide-btn" bindtap="toggleAmount">{{hideAmount ? '👁️‍🗨️' : '👁️'}}</view>
    </view>
    <view class="main-amount">
      <text class="currency">¥</text>
      <text class="amount {{hideAmount ? 'hidden' : ''}}">{{hideAmount ? '***.**' : totalDebtDisplay}}</text>
    </view>
    <view class="data-row">
      <view class="data-item">
        <view class="data-item-label">本月待还</view>
        <view class="data-item-value highlight">{{hideAmount ? '***' : '¥' + monthRepayDisplay}}</view>
      </view>
      <view class="data-item">
        <view class="data-item-label">清零倒计时</view>
        <view class="data-item-value">{{clearDays}}天</view>
      </view>
      <view class="data-item">
        <view class="data-item-label">负债渠道</view>
        <view class="data-item-value">{{activeCount}}个</view>
      </view>
    </view>
    <view class="progress-section">
      <view class="progress-header">
        <text class="progress-text">还款进度</text>
        <text class="progress-text">{{progress}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
    </view>
  </view>

  <!-- 数据可视化区域 -->
  <view class="visual-section" wx:if="{{channels.length > 0}}">
    <view class="visual-header">
      <view class="visual-title">数据分析</view>
      <view class="visual-tabs">
        <view class="visual-tab {{visualTab==='trend'?'active':''}}" bindtap="switchVisualTab" data-type="trend">趋势</view>
        <view class="visual-tab {{visualTab==='pie'?'active':''}}" bindtap="switchVisualTab" data-type="pie">占比</view>
      </view>
    </view>
    
    <!-- 趋势图 -->
    <view class="chart-container" wx:if="{{visualTab==='trend'}}">
      <view class="trend-chart">
        <view class="chart-y-axis">
          <text>{{trendMax}}</text>
          <text>{{trendMid}}</text>
          <text>0</text>
        </view>
        <view class="trend-bars">
          <view class="trend-bar-item" wx:for="{{trendData}}" wx:key="month">
            <view class="bar-wrapper">
              <view class="trend-bar" style="height: {{item.percent}}%"></view>
            </view>
            <text class="bar-label">{{item.month}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 饼图 -->
    <view class="chart-container" wx:if="{{visualTab==='pie'}}">
      <view class="pie-chart">
        <view class="pie-circle">
          <view class="pie-center">
            <text class="pie-total">{{totalDebtDisplay}}</text>
            <text class="pie-label">总负债</text>
          </view>
        </view>
      </view>
      <view class="pie-legend">
        <view class="legend-item" wx:for="{{pieData}}" wx:key="type">
          <view class="legend-dot" style="background:{{item.color}}"></view>
          <text class="legend-name">{{item.name}}</text>
          <text class="legend-value">{{item.percentage}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="motivation-banner" wx:if="{{channels.length > 0}}">
    <view class="motivation-text">{{motivationText}}</view>
    <view class="motivation-sub">已还款 {{progress}}%，继续加油！</view>
  </view>

  <view class="warning-card" wx:if="{{warnings.length > 0}}">
    <view class="warning-header">
      <view class="warning-icon">⚠️</view>
      <view class="warning-title">到期提醒</view>
    </view>
    <view class="warning-item {{item.levelClass}}" wx:for="{{warnings}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="warning-info">
        <view class="warning-name">{{item.name}}</view>
        <view class="warning-day {{item.dayClass}}">{{item.dayText}}</view>
      </view>
      <view class="warning-amount">¥{{item.monthlyPaymentDisplay}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">我的负债</view>
      <view class="sort-btn" bindtap="toggleSort">
        <text>{{sortLabel}}</text>
        <text>▼</text>
      </view>
    </view>

    <view wx:if="{{sortedChannels.length === 0}}" class="empty-state">
      <view class="empty-icon">💰</view>
      <view class="empty-text">暂无负债记录</view>
      <view class="empty-hint">点击下方按钮添加您的第一笔负债</view>
    </view>

    <view class="channel-card" wx:for="{{sortedChannels}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}" bindlongpress="showQuickMenu" data-channel="{{item}}">
      <view class="channel-header">
        <view class="type-tag type-{{item.type}}">{{item.typeName}}</view>
        <view class="channel-name">{{item.name}}</view>
      </view>
      <view class="channel-amount">
        <text class="amount-label">剩余</text>
        <text class="amount-value">¥ {{item.remainingDisplay}}</text>
      </view>
      <view class="channel-progress">
        <view class="progress-bar-sm">
          <view class="progress-fill-sm" style="width: {{item.progress}}%"></view>
        </view>
        <text class="progress-label">已还 {{item.progress}}%</text>
      </view>
      <view class="channel-footer">
        <text class="channel-date">还款日: 每月{{item.repaymentDay}}日</text>
        <text class="channel-action">查看详情 →</text>
      </view>
      <view class="channel-overdue" wx:if="{{item.overdueDays > 0}}">🚨 已逾期 {{item.overdueDays}} 天</view>
    </view>
  </view>

  <view class="fab-btn" bindtap="goAdd">+</view>

  <view class="quick-menu" wx:if="{{showQuickMenu}}" bindtap="closeQuickMenu">
    <view class="quick-menu-content" catchtap="">
      <view style="text-align:center; margin-bottom:32rpx; font-size:32rpx; font-weight:600;">{{quickChannel.name}}</view>
      <view class="quick-menu-item" bindtap="quickRepay">
        <text class="quick-menu-icon">💰</text>
        <text class="quick-menu-text">立即还款</text>
      </view>
      <view class="quick-menu-item" bindtap="quickEdit">
        <text class="quick-menu-icon">✏️</text>
        <text class="quick-menu-text">编辑</text>
      </view>
      <view class="quick-menu-item danger" bindtap="quickDelete">
        <text class="quick-menu-icon">🗑️</text>
        <text class="quick-menu-text">删除</text>
      </view>
    </view>
  </view>
</view>