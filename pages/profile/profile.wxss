.profile-page { min-height: 100vh; background: #F5F7FA; padding-bottom: 120rpx; }
.profile-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 60rpx 48rpx 60rpx;
  display: flex; align-items: center; gap: 32rpx;
}
.avatar {
  width: 120rpx; height: 120rpx; background: rgba(255,255,255,0.3); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 56rpx;
  border: 4rpx solid rgba(255,255,255,0.5); overflow: hidden;
}
.avatar-img { width: 100%; height: 100%; }
.user-info { flex: 1; }
.nickname { font-size: 36rpx; font-weight: 700; color: #FFFFFF; margin-bottom: 8rpx; }
.user-stats { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.stats-grid {
  display: flex; background: #FFFFFF; margin: -40rpx 40rpx 40rpx; border-radius: 32rpx;
  padding: 40rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08); position: relative; z-index: 2;
}
.stats-grid-item { flex: 1; text-align: center; position: relative; }
.stats-grid-item:not(:last-child)::after {
  content: ''; position: absolute; right: 0; top: 20%; height: 60%; width: 2rpx; background: #E2E8F0;
}
.stats-grid-value { font-size: 44rpx; font-weight: 700; margin-bottom: 8rpx; }
.stats-grid-value.primary { color: #FF6B6B; }
.stats-grid-value.success { color: #4ECDC4; }
.stats-grid-value.warning { color: #F39C12; }
.stats-grid-label { font-size: 24rpx; color: #718096; }
.menu-section {
  background: #FFFFFF; margin: 0 40rpx 40rpx; border-radius: 32rpx;
  overflow: hidden; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}
.menu-item {
  display: flex; align-items: center; padding: 32rpx 40rpx; border-bottom: 2rpx solid #E2E8F0;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  width: 72rpx; height: 72rpx; background: #F8FAFC; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center; margin-right: 28rpx; font-size: 36rpx;
}
.menu-text { flex: 1; font-size: 30rpx; color: #1A202C; }
.menu-arrow { color: #A0AEC0; font-size: 36rpx; }
.reward-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 999;
  display: flex; align-items: center; justify-content: center;
}
.reward-content { background: #fff; padding: 40rpx; border-radius: 16rpx; text-align: center; }
.reward-img { width: 500rpx; height: auto; }
.reward-tip { margin-top: 20rpx; color: #666; font-size: 28rpx; }