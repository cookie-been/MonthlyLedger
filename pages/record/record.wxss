.record-page { min-height: 100vh; background: #F5F7FA; padding-bottom: 40rpx; }
.record-header {
  background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);
  padding: 120rpx 48rpx 80rpx;
  color: #FFFFFF;
}
.record-title { font-size: 48rpx; font-weight: 700; margin-bottom: 16rpx; }
.record-stats { display: flex; gap: 32rpx; margin-top: 32rpx; }
.record-stat {
  background: rgba(255,255,255,0.2);
  padding: 24rpx;
  border-radius: 24rpx;
  flex: 1;
  text-align: center;
}
.record-stat-label { font-size: 24rpx; opacity: 0.9; margin-bottom: 8rpx; }
.record-stat-value { font-size: 40rpx; font-weight: 700; }
.filter-bar { display: flex; gap: 16rpx; margin: 0 40rpx 32rpx; padding-top: 32rpx; }
.filter-item { padding: 16rpx 32rpx; background: #FFFFFF; border-radius: 40rpx; font-size: 26rpx; color: #718096; }
.filter-item.active { background: #FF6B6B; color: #FFFFFF; }
.record-item {
  display: flex; align-items: center; background: #FFFFFF; margin: 0 40rpx 24rpx;
  border-radius: 32rpx; padding: 32rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}
.record-icon {
  width: 96rpx; height: 96rpx; background: #E8F8F5; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; color: #4ECDC4;
  font-size: 40rpx; margin-right: 28rpx;
}
.record-info { flex: 1; }
.record-channel { font-size: 30rpx; font-weight: 600; margin-bottom: 8rpx; }
.record-time { font-size: 24rpx; color: #A0AEC0; }
.record-note { font-size: 24rpx; color: #718096; margin-top: 8rpx; }
.record-amount { font-size: 36rpx; font-weight: 700; color: #4ECDC4; }