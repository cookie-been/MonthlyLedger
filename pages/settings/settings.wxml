<view class="settings-page">
  <view class="settings-header">
    <view class="settings-title">设置</view>
  </view>
  <view class="setting-section">
    <view class="setting-section-title">快捷入口</view>
    <view class="setting-item" bindtap="goCalendar">
      <text class="setting-label">还款日历</text>
      <text class="setting-value">›</text>
    </view>
  </view>
  <view class="setting-section">
    <view class="setting-section-title">提醒设置</view>
    <view class="setting-item">
      <text class="setting-label">还款提醒</text>
      <switch checked="{{settings.reminderEnabled}}" bindchange="toggleReminder" color="#FF6B6B"/>
    </view>
    <view class="setting-item">
      <text class="setting-label">提醒时间</text>
      <text class="setting-value">{{settings.reminderTime}}</text>
    </view>
    <view class="setting-item">
      <text class="setting-label">提前提醒天数</text>
      <text class="setting-value">{{settings.reminderAdvance}}天</text>
    </view>
  </view>
  <view class="setting-section">
    <view class="setting-section-title">安全设置</view>
    <view class="setting-item">
      <text class="setting-label">金额隐藏</text>
      <switch checked="{{settings.hideAmount}}" bindchange="toggleHideAmount" color="#FF6B6B"/>
    </view>
  </view>
  <view class="setting-section">
    <view class="setting-section-title">数据管理</view>
    <view class="setting-item" bindtap="exportData">
      <text class="setting-label">导出数据(JSON)</text>
      <text class="setting-value">›</text>
    </view>
    <view class="setting-item" bindtap="importData">
      <text class="setting-label">导入数据(JSON)</text>
      <text class="setting-value">›</text>
    </view>
    <view class="setting-item" bindtap="clearData">
      <text class="setting-label">清除所有数据</text>
      <text class="setting-value">›</text>
    </view>
  </view>
  <view class="setting-section">
    <view class="setting-section-title">关于</view>
    <view class="setting-item">
      <text class="setting-label">当前版本</text>
      <text class="setting-value">v2.0.0</text>
    </view>
  </view>
</view>