.splash-container {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.splash-content {
  text-align: center;
  color: #FFFFFF;
}

.splash-logo {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  animation: float 2s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.splash-title {
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.splash-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 60rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  margin: 0 auto 40rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.splash-version {
  font-size: 24rpx;
  opacity: 0.7;
}