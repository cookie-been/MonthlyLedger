<view class="suggestion-page">
  <view class="suggestion-header">
    <view class="suggestion-title">还款建议</view>
    <view class="suggestion-desc">智能推荐最优还款策略</view>
  </view>

  <view class="strategy-tabs">
    <view class="strategy-tab {{selectedStrategy==='snowball'?'active':''}}" bindtap="selectStrategy" data-strategy="snowball">
      <text class="tab-name">雪球法</text>
      <text class="tab-desc">还最小债务</text>
    </view>
    <view class="strategy-tab {{selectedStrategy==='avalanche'?'active':''}}" bindtap="selectStrategy" data-strategy="avalanche">
      <text class="tab-name">雪崩法</text>
      <text class="tab-desc">节省利息</text>
    </view>
  </view>

  <view class="strategy-info" wx:if="{{selectedStrategy === 'snowball'}}">
    <view class="info-icon">🎯</view>
    <view class="info-text">优先还清最小额度的债务，快速看到第一个还清的结果，获得成就感</view>
  </view>
  <view class="strategy-info" wx:if="{{selectedStrategy === 'avalanche'}}">
    <view class="info-icon">💰</view>
    <view class="info-text">优先还清利率最高的债务，长期来看可以节省更多利息支出</view>
  </view>

  <view class="plan-section">
    <view class="plan-title">还款计划</view>
    <view class="plan-empty" wx:if="{{currentChannels.length === 0}}">暂无待还账单</view>
    <view class="plan-list">
      <view class="plan-item" wx:for="{{currentChannels}}" wx:key="id" wx:for-index="idx">
        <view class="plan-num">{{idx + 1}}</view>
        <view class="plan-detail">
          <view class="plan-name">{{item.name}}</view>
          <view class="plan-reason" wx:if="{{selectedStrategy === 'snowball'}}">剩余 {{item.remainingDisplay}} 最少</view>
          <view class="plan-reason" wx:if="{{selectedStrategy === 'avalanche'}}">利率 {{item.interestRate || 0}}% 最高</view>
        </view>
        <view class="plan-amount">
          <text class="amount-value">¥{{item.monthlyDisplay}}</text>
          <text class="amount-label">/月</text>
        </view>
      </view>
    </view>
  </view>

  <view class="summary-section">
    <view class="summary-card">
      <view class="summary-item">
        <text class="summary-label">总账单</text>
        <text class="summary-value primary">¥{{totalDebtDisplay}}</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-label">月还款</text>
        <text class="summary-value">¥{{monthlyPaymentDisplay}}</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-label">预计清零</text>
        <text class="summary-value success">{{clearDate}}</text>
      </view>
    </view>
  </view>
</view>